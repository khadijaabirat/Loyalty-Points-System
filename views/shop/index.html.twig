{% extends './layouts/base.twig' %}

{% block title %}Boutique - ShopEasy{% endblock %}

{% block content %}
    <div class="shop-header">
        <h1><i class="fas fa-store"></i> Notre Boutique</h1>
        <div class="shop-info">
            <div class="info-badge">
                <i class="fas fa-star"></i>
                <span>Gagnez <strong>10 points</strong> par tranche de <strong>100$</strong></span>
            </div>
        </div>
    </div>

    <div class="shop-filters">
        <form action="/Loyalty_Points_System/public/shop" method="GET" class="search-form">
            <div class="search-input-wrapper">
                <i class="fas fa-search"></i>
                <input type="text" name="search" placeholder="Rechercher un produit..." value="{{ current_search }}" class="search-input">
            </div>
            
            <div class="category-pills">
                <a href="/Loyalty_Points_System/public/shop{% if current_search %}?search={{ current_search }}{% endif %}" class="category-pill {% if not current_category %}active{% endif %}">Tout</a>
                {% for cat in categories %}
                    <a href="/Loyalty_Points_System/public/shop?category={{ cat|url_encode }}{% if current_search %}&search={{ current_search|url_encode }}{% endif %}" class="category-pill {% if current_category == cat %}active{% endif %}">{{ cat }}</a>
                {% endfor %}
            </div>
        </form>
    </div>

    {% if products is empty %}
        <div class="empty-state" style="margin-top: 40px;">
            <div class="empty-icon"><i class="fas fa-box-open" style="font-size: 3rem; color: var(--text-tertiary);"></i></div>
            <h2 style="margin-top: 16px;">Aucun produit trouvé</h2>
            <p style="margin-bottom: 24px;">Essayez de modifier votre recherche ou vos filtres.</p>
            <a href="/Loyalty_Points_System/public/shop" class="btn btn-secondary">Réinitialiser les filtres</a>
        </div>
    {% else %}
        <div class="products-grid">
            {% for product in products %}
                <div class="product-card">
                    <div class="product-badge">
                        <i class="fas fa-fire"></i>
                        <span>{{ product.category }}</span>
                    </div>
                    <div class="product-image">
                        <img src="{{ product.image }}" alt="{{ product.name }}" class="product-img">
                    </div>
                    <div class="product-info">
                        <h3 class="product-name">{{ product.name }}</h3>
                        <p class="product-description">{{ product.description }}</p>
                        <div class="product-footer">
                            <p class="product-price">
                                <span class="currency">$</span>
                                <span class="amount">{{ product.price|number_format(2, '.', ' ') }}</span>
                            </p>
                            <div class="product-points">
                                <i class="fas fa-star"></i>
                                <span>+{{ (product.price / 100 * 10)|round(0, 'floor') }} pts</span>
                            </div>
                        </div>
                    </div>
                    <form action="/Loyalty_Points_System/public/shop/add-to-cart" method="POST" class="add-to-cart-form">
                        <input type="hidden" name="product_id" value="{{ product.id }}">
                        <div class="quantity-selector">
                            <label for="qty-{{ product.id }}">
                                <i class="fas fa-boxes"></i>
                                Quantité
                            </label>
                            <input type="number" id="qty-{{ product.id }}" name="quantity" value="1" min="1" max="99">
                        </div>
                        <button type="submit" class="btn btn-primary btn-add-cart">
                            <i class="fas fa-cart-plus"></i>
                            <span>Ajouter au panier</span>
                        </button>
                    </form>
                </div>
            {% endfor %}
        </div>
    {% endif %}
{% endblock %}
