{% extends './layouts/base.twig' %}

{% block title %}Commande confirmée - ShopEasy{% endblock %}

{% block content %}
<div class="purchase-result">
    {% if purchase is defined and purchase is not null %}
        <div class="success-icon">
            <i class="fas fa-check-circle"></i>
        </div>
        <h1>Commande confirmée !</h1>
        <p class="success-message">
            <i class="fas fa-heart"></i>
            Merci pour votre achat, <strong>{{ user.name }}</strong> !
        </p>

        <div class="result-card">
            <h2><i class="fas fa-box"></i> Détails de votre commande</h2>
            <p class="order-date">
                <i class="fas fa-calendar-alt"></i>
                Date: {{ purchase.date }}
            </p>
            
            <table class="result-table">
                <thead>
                    <tr>
                        <th><i class="fas fa-tag"></i> Produit</th>
                        <th><i class="fas fa-sort-numeric-up"></i> Quantité</th>
                        <th><i class="fas fa-dollar-sign"></i> Prix Total</th>
                    </tr>
                </thead>
                <tbody>
                    {% for item in purchase.items %}
                        <tr>
                            <td style="display: flex; align-items: center; gap: 12px;">
                                {% if item.image is defined and item.image is not empty %}
                                    <img src="{{ item.image }}" alt="{{ item.name }}" style="width: 40px; height: 40px; border-radius: 6px; object-fit: cover;">
                                {% else %}
                                    <span style="font-size: 1.5rem;">📦</span>
                                {% endif %}
                                {{ item.name }}
                            </td>
                            <td style="text-align: center;">{{ item.quantity }}</td>
                            <td style="text-align: right;">{{ (item.price * item.quantity)|number_format(2, '.', ' ') }} $</td>
                        </tr>
                    {% endfor %}
                </tbody>
                <tfoot>
                    <tr>
                        <td colspan="2" style="text-align: right;">Total payé</td>
                        <td style="text-align: right;">{{ purchase.total|number_format(2, '.', ' ') }} $</td>
                    </tr>
                </tfoot>
            </table>
        </div>

        <div class="points-result-card">
            <h2><i class="fas fa-star"></i> Points de fidélité</h2>
            
            <div class="points-summary">
                <p>
                    <span><i class="fas fa-plus-circle"></i> Points gagnés</span>
                    <strong style="color: #10b981;">+{{ purchase.points_earned }} points</strong>
                </p>
                <p>
                    <span><i class="fas fa-history"></i> Ancien solde</span>
                    <span>{{ purchase.previous_points }} points</span>
                </p>
                <p>
                    <span><i class="fas fa-wallet"></i> Nouveau solde</span>
                    <strong>{{ purchase.new_points }} points</strong>
                </p>
            </div>

            <p class="points-calculation">
                <i class="fas fa-calculator"></i>
                <strong>Calcul:</strong> {{ purchase.total|number_format(2, '.', ' ') }} $ / 100 = {{ (purchase.total / 100)|round(0, 'floor') }} tranches x 10 = <strong>{{ purchase.points_earned }} points</strong>
            </p>
        </div>

        <div class="result-actions">
            <a href="/Loyalty_Points_System/public/shop" class="btn btn-primary btn-large">
                <i class="fas fa-shopping-bag"></i>
                <span>Continuer mes achats</span>
            </a>
            <a href="/Loyalty_Points_System/public/dashboard" class="btn btn-secondary btn-large">
                <i class="fas fa-chart-line"></i>
                <span>Voir mon profil</span>
            </a>
        </div>
    {% else %}
        <div class="empty-state">
            <div class="empty-icon">
                <i class="fas fa-exclamation-triangle"></i>
            </div>
            <h2>Oops!</h2>
            <p>Aucune donnée de commande récente trouvée.</p> 
            <a href="/Loyalty_Points_System/public/shop" class="btn btn-primary btn-large">
                <i class="fas fa-store"></i>
                <span>Retour à la boutique</span>
            </a>
        </div>
    {% endif %}
</div>
{% endblock %}