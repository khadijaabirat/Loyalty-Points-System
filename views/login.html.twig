{% extends 'layouts/base.twig' %}

{% block title %}Connexion - ShopEasy{% endblock %}

{% block content %}
<div class="auth-wrapper">
    <div class="auth-card">
        <div class="auth-header">
            <div class="auth-icon">
                <i class="fas fa-lock"></i>
            </div>
            <h1 class="auth-title">Bienvenue</h1>
            <p class="auth-subtitle">Connectez-vous pour continuer vos achats</p>
        </div>

        {% if error %}
            <div class="auth-alert auth-alert-error">
                <i class="fas fa-exclamation-circle"></i>
                <span>{{ error }}</span>
            </div>
        {% endif %}

        <form method="POST" action="/Loyalty_Points_System/public/login" class="auth-form">
            <div class="form-group">
                <label>
                    <i class="fas fa-envelope"></i>
                    Email
                </label>
                <input type="email" name="email" placeholder="votre@email.com" required autofocus>
            </div>

            <div class="form-group">
                <label>
                    <i class="fas fa-key"></i>
                    Mot de passe
                </label>
                <input type="password" name="password" placeholder="••••••••" required>
            </div>

            <div class="auth-actions">
                <button class="btn btn-primary btn-full">
                    <i class="fas fa-sign-in-alt"></i>
                    <span>Se connecter</span>
                </button>
            </div>
        </form>

        <div class="auth-divider">
            <span>ou</span>
        </div>

        <div class="auth-footer">
            <p>Pas encore de compte ?</p>
            <a href="/Loyalty_Points_System/public/register" class="auth-link">
                Créer un compte gratuitement
                <i class="fas fa-arrow-right"></i>
            </a>
        </div>
    </div>
</div>
{% endblock %}
