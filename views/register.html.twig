{% extends 'layouts/base.twig' %}

{% block title %}Inscription - ShopEasy{% endblock %}

{% block content %}
<div class="auth-wrapper">
    <div class="auth-card">
        <div class="auth-header">
            <div class="auth-icon register-icon">
                <i class="fas fa-user-plus"></i>
            </div>
            <h1 class="auth-title">Rejoignez-nous</h1>
            <p class="auth-subtitle">Créez votre compte et profitez de nos avantages</p>
        </div>

        {% if error_global %}
            <div class="auth-alert auth-alert-error">
                <i class="fas fa-exclamation-circle"></i>
                <span>{{ error_global }}</span>
            </div>
        {% endif %}

        <form method="POST" action="/Loyalty_Points_System/public/register" class="auth-form">
            <div class="form-group">
                <label>
                    <i class="fas fa-user"></i>
                    Nom complet
                </label>
                <input type="text" name="name" placeholder="John Doe" required autofocus>
            </div>

            <div class="form-group">
                <label>
                    <i class="fas fa-envelope"></i>
                    Adresse email
                </label>
                <input type="email" name="email" placeholder="votre@email.com" required>
            </div>

            <div class="form-group">
                <label>
                    <i class="fas fa-key"></i>
                    Mot de passe
                </label>
                <input type="password" name="password" placeholder="••••••••" required>
            </div>

            <div class="benefits-box">
                <h4><i class="fas fa-gift"></i> Avantages membres</h4>
                <ul>
                    <li><i class="fas fa-check"></i> 10 points par 100$ d'achat</li>
                    <li><i class="fas fa-check"></i> Réductions exclusives</li>
                    <li><i class="fas fa-check"></i> Offres personnalisées</li>
                </ul>
            </div>

            <div class="auth-actions">
                <button class="btn btn-primary btn-full">
                    <i class="fas fa-rocket"></i>
                    <span>Créer mon compte</span>
                </button>
            </div>
        </form>

        <div class="auth-divider">
            <span>ou</span>
        </div>

        <div class="auth-footer">
            <p>Déjà membre ?</p>
            <a href="/Loyalty_Points_System/public/login" class="auth-link">
                Se connecter
                <i class="fas fa-arrow-right"></i>
            </a>
        </div>
    </div>
</div>
{% endblock %}
